# ============================================================================
# Infrastructure Dashboard Configuration
# Copy this file to .env and fill in your own values
# .env is gitignored and should NOT be committed to the repository
# ============================================================================

# ============================================================================
# Project & Environment Configuration
# ============================================================================

# Project name (used for HuggingFace Spaces and service URLs)
ProjectName=my-project

# Environment (Dev, Test, Prod)
Environment=Dev

# ============================================================================
# Services Configuration
# ============================================================================

# Comma-separated list of service/space names
# These will be created as HuggingFace Spaces
# Examples: Airflow, MLflow, JupyterLab
ServicesNames=Airflow,MLflow,JupyterLab,Streamlit,n8n,Gradio,EvidentlyAI,ClickHouse

# ============================================================================
# External Resources URLs
# ============================================================================

# GitHub repository URL
GitHubURL=https://github.com/your-org/your-repo

# S3 storage URLs (for MLflow artifacts, etc.)
S3URLs=https://supabase.com/dashboard/project/golucliredxdcemqhwsw/storage/files

# Database URLs (for Airflow, n8n, etc.)
DatabaseURLs=https://console.neon.tech/app/projects/royal-lab-13272228/branches/br-flat-queen-ag6s14xs/tables

# ============================================================================
# HuggingFace Configuration (for GitHub Actions)
# ============================================================================

# HuggingFace API token (with write access)
# Add this as a GitHub Secret: HF_TOKEN
# HF_TOKEN=hf_****

# HuggingFace username
# Add this as a GitHub Secret: HF_USERNAME
# HF_USERNAME=your-hf-username

# ============================================================================
# AWS Secrets (add these as GitHub Secrets)
# These are shared across ALL HuggingFace Spaces
# ============================================================================

# AWS Access Key ID
# Add as GitHub Secret: AWS_ACCESS_KEY_ID
# AWS_ACCESS_KEY_ID=AKIA...

# AWS Secret Access Key
# Add as GitHub Secret: AWS_SECRET_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=***

# AWS Session Token (optional, if using temporary credentials)
# Add as GitHub Secret: AWS_SESSION_TOKEN
# AWS_SESSION_TOKEN=***

# AWS Default Region
# Add as GitHub Secret: AWS_DEFAULT_REGION
# AWS_DEFAULT_REGION=us-east-1

# ============================================================================
# MLflow Specific Secrets
# ============================================================================

# MLflow S3 Endpoint URL (for S3/MinIO storage)
# Add as GitHub Secret: MLFLOW_S3_ENDPOINT_URL
# MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# MLflow S3 Bucket name
# Add as GitHub Secret: MLFLOW_S3_BUCKET
# MLFLOW_S3_BUCKET=mlflow-artifacts

# MLflow PostgreSQL URI for tracking database
# Add as GitHub Secret: MLFLOW_POSTGRESQL_URI
# MLFLOW_POSTGRESQL_URI=postgresql://user:password@localhost:5432/mlflow

# ============================================================================
# Airflow Specific Secrets
# ============================================================================

# Airflow PostgreSQL Connection ID
# Add as GitHub Secret: AIRFLOW_POSTGRES_CONN_ID
# AIRFLOW_POSTGRES_CONN_ID=postgresql://airflow:airflow@localhost:5432/airflow

# Airflow S3 Connection ID
# Add as GitHub Secret: AIRFLOW_S3_CONN_ID
# AIRFLOW_S3_CONN_ID=s3://access-key:secret-key@bucket-name

# ============================================================================
# JupyterLab Specific Secrets
# ============================================================================

# JupyterLab Token for authentication
# Add as GitHub Secret: JUPYTER_TOKEN
# JUPYTER_TOKEN=your-jupyter-token

# ============================================================================
# n8n Specific Secrets
# ============================================================================

# n8n Database PostgreSQL URI
# Add as GitHub Secret: N8N_DB_POSTGRES_URI
# N8N_DB_POSTGRES_URI=postgresql://user:password@localhost:5432/n8n

# ============================================================================
# Streamlit Specific Secrets
# ============================================================================

# Streamlit API Key
# Add as GitHub Secret: STREAMLIT_API_KEY
# STREAMLIT_API_KEY=***
